# ============================================================
# Environment variable template — committed to git as a reference.
# Copy this to .env.local and fill in real values for local dev.
# For production, set the same keys in Vercel → Project Settings →
# Environment Variables. Never commit real secrets to this file.
# ============================================================

# Kartra API — used by /api/subscribe and the Kartra wrapper in
# lib/kartra.ts. All three values required together; missing any one
# returns "invalid auth" from Kartra.
KARTRA_APP_ID=
KARTRA_API_KEY=
KARTRA_API_PASSWORD=
